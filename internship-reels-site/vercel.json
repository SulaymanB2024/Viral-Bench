{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/library",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/signals",
      "destination": "/dashboard",
      "permanent": true
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "data/**",
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/media/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    },
    {
      "source": "/operator",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
