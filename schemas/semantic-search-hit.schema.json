{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viral-bench.local/schemas/semantic-search-hit.schema.json",
  "title": "Semantic Search Hit",
  "type": "object",
  "additionalProperties": false,
  "required": ["item_id", "evidence_id", "post_id", "item_type", "text", "canonical_url", "timestamped_url", "start_sec", "end_sec", "platform", "account_handle", "hashtags", "retrieval_relevance", "semantic_similarity", "observed_coas", "predicted_coas", "freshness", "confidence", "rank_sources"],
  "properties": {
    "item_id": { "type": "string", "minLength": 1 },
    "evidence_id": { "type": "string", "minLength": 1 },
    "post_id": { "type": "string", "minLength": 1 },
    "item_type": { "type": "string", "enum": ["video_segment", "caption", "pegasus_description", "comment", "account", "hashtag"] },
    "text": { "type": "string" },
    "canonical_url": { "type": "string", "format": "uri" },
    "timestamped_url": { "type": "string", "format": "uri" },
    "start_sec": { "type": ["number", "null"], "minimum": 0 },
    "end_sec": { "type": ["number", "null"], "minimum": 0 },
    "platform": { "type": "string", "enum": ["tiktok", "instagram", "youtube_shorts"] },
    "account_handle": { "type": "string", "minLength": 1 },
    "hashtags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "retrieval_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
    "semantic_similarity": { "type": ["number", "null"], "minimum": -1, "maximum": 1 },
    "observed_coas": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "predicted_coas": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "freshness": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rank_sources": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "enum": ["vector", "fts"] } }
  }
}
