{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "provider-spend-event-v1.schema.json",
  "type": "object",
  "required": ["schema_version", "program_id", "run_id", "route_id", "provider", "actor_or_model", "input_hash", "reserved_usd", "program_ceiling_usd", "prior_conservative_spend_usd", "conservative_spend_usd", "settlement_state", "retries", "occurred_at", "stop_state", "output_hashes"],
  "properties": {
    "schema_version": { "const": "provider_spend_event_v1" },
    "program_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "route_id": { "type": "string", "minLength": 1 },
    "provider": { "enum": ["apify", "twelvelabs"] },
    "actor_or_model": { "type": "string", "minLength": 1 },
    "build_or_revision": { "type": ["string", "null"] },
    "input_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "asset_hashes": { "type": "array", "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
    "reserved_usd": { "type": "number", "minimum": 0 },
    "program_ceiling_usd": { "type": "number", "minimum": 0 },
    "prior_conservative_spend_usd": { "type": "number", "minimum": 0 },
    "actual_provider_cost_usd": { "type": ["number", "null"], "minimum": 0 },
    "usage_pricing_estimate_usd": { "type": ["number", "null"], "minimum": 0 },
    "conservative_spend_usd": { "type": "number", "minimum": 0 },
    "settlement_state": { "enum": ["settled", "pending", "unknown", "failed"] },
    "retries": { "type": "integer", "minimum": 0 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "settled_at": { "type": ["string", "null"], "format": "date-time" },
    "stop_state": { "enum": ["running", "completed", "partial", "blocked", "stopped"] },
    "stop_reason": { "type": ["string", "null"] },
    "output_hashes": { "type": "array", "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }
  }
}
