{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viral-bench.local/schemas/internship-selection-ledger.schema.json",
  "title": "Internship Content Selection Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "batch_id", "generated_at", "target_total", "entries", "identity_groups", "counts", "shortfalls", "evidence_boundary"],
  "properties": {
    "schema_version": { "const": 1 },
    "batch_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "target_total": { "const": 36 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "candidate_source", "canonical_url", "platform", "platform_post_id", "account_handle", "source_group", "chosen_pillar", "cohort", "source_groups_observed", "chosen_pillars_observed", "cohorts_observed", "observation_count", "observations", "posted_at", "age_bucket", "metrics", "classification_basis", "classification_version", "classification_confidence", "human_override", "selected", "selection_reason", "exclusion_reason", "normalized_performance_score", "evidence_richness", "novelty_score"],
        "properties": {
          "candidate_id": { "type": "string", "minLength": 1 },
          "candidate_source": { "type": ["string", "null"] },
          "canonical_url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "platform": { "type": "string", "enum": ["tiktok", "instagram", "youtube_shorts"] },
          "platform_post_id": { "type": "string", "minLength": 1 },
          "account_handle": { "type": "string", "minLength": 1 },
          "source_group": { "type": "string", "enum": ["competitor_product", "student_problem_creator", "opportunity_access_safety", "contrast_outlier"] },
          "chosen_pillar": { "type": "string", "enum": ["competitor_product", "student_problem_creator", "opportunity_access_safety", "contrast_outlier"] },
          "cohort": { "type": "string", "enum": ["recent", "popular"] },
          "source_groups_observed": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "enum": ["competitor_product", "student_problem_creator", "opportunity_access_safety", "contrast_outlier"] }
          },
          "chosen_pillars_observed": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "enum": ["competitor_product", "student_problem_creator", "opportunity_access_safety", "contrast_outlier"] }
          },
          "cohorts_observed": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "enum": ["recent", "popular"] }
          },
          "observation_count": { "type": "integer", "minimum": 1 },
          "observations": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/candidate_observation" }
          },
          "posted_at": { "type": ["string", "null"], "format": "date-time" },
          "age_bucket": { "type": "string", "enum": ["0_90_days", "91_365_days", "older_than_365_days", "unknown"] },
          "metrics": {
            "type": "object",
            "additionalProperties": false,
            "required": ["views", "likes", "comments", "shares", "saves"],
            "properties": {
              "views": { "type": ["number", "null"], "minimum": 0 },
              "likes": { "type": ["number", "null"], "minimum": 0 },
              "comments": { "type": ["number", "null"], "minimum": 0 },
              "shares": { "type": ["number", "null"], "minimum": 0 },
              "saves": { "type": ["number", "null"], "minimum": 0 }
            }
          },
          "classification_basis": { "type": ["string", "null"] },
          "classification_version": { "type": ["string", "null"] },
          "classification_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "human_override": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/human_override" }] },
          "selected": { "type": "boolean" },
          "selection_reason": { "type": ["string", "null"] },
          "exclusion_reason": { "type": ["string", "null"] },
          "normalized_performance_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "evidence_richness": { "type": "number", "minimum": 0, "maximum": 1 },
          "novelty_score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "identity_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["identity_key", "canonical_candidate_id", "candidate_ids", "candidate_sources", "source_groups_observed", "chosen_pillars_observed", "cohorts_observed", "observation_count", "divergence_fields"],
        "properties": {
          "identity_key": { "type": "string", "minLength": 1 },
          "canonical_candidate_id": { "type": "string", "minLength": 1 },
          "candidate_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "candidate_sources": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "source_groups_observed": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
          "chosen_pillars_observed": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
          "cohorts_observed": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["recent", "popular"] } },
          "observation_count": { "type": "integer", "minimum": 1 },
          "divergence_fields": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "counts": { "type": "object" },
    "shortfalls": { "type": "array", "items": { "type": "string" } },
    "evidence_boundary": {
      "type": "object",
      "required": ["raw_cross_platform_ranking_allowed", "selection_is_performance_prediction"],
      "properties": {
        "raw_cross_platform_ranking_allowed": { "const": false },
        "selection_is_performance_prediction": { "const": false }
      }
    }
  },
  "$defs": {
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["views", "likes", "comments", "shares", "saves"],
      "properties": {
        "views": { "type": ["number", "null"], "minimum": 0 },
        "likes": { "type": ["number", "null"], "minimum": 0 },
        "comments": { "type": ["number", "null"], "minimum": 0 },
        "shares": { "type": ["number", "null"], "minimum": 0 },
        "saves": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "human_override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "reviewed_at", "reason", "selection_group"],
      "properties": {
        "reviewer": { "type": "string", "minLength": 1 },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 },
        "selection_group": { "enum": ["competitor_product", "student_problem_creator", "opportunity_access_safety", "contrast_outlier"] }
      }
    },
    "candidate_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "candidate_source", "source_group", "chosen_pillar", "cohort", "posted_at", "metrics", "classification_basis", "classification_version", "classification_confidence", "human_override"],
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "candidate_source": { "type": ["string", "null"] },
        "source_group": { "enum": ["competitor_product", "student_problem_creator", "opportunity_access_safety", "contrast_outlier"] },
        "chosen_pillar": { "enum": ["competitor_product", "student_problem_creator", "opportunity_access_safety", "contrast_outlier"] },
        "cohort": { "enum": ["recent", "popular"] },
        "posted_at": { "type": ["string", "null"], "format": "date-time" },
        "metrics": { "$ref": "#/$defs/metrics" },
        "classification_basis": { "type": ["string", "null"] },
        "classification_version": { "type": ["string", "null"] },
        "classification_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "human_override": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/human_override" }] }
      }
    }
  }
}
