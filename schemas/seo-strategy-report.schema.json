{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viral-bench.local/schemas/seo-strategy-report.schema.json",
  "title": "Evidence-Bounded SEO Strategy Report",
  "type": "object",
  "required": ["strategy_id", "research_id", "created_at", "niche", "evidence_summary", "observed_patterns", "derived_recommendations", "search_intent", "house_style", "originality_constraints", "content_concepts", "limitations", "approval_state"],
  "properties": {
    "strategy_id": { "type": "string", "minLength": 1 },
    "research_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "niche": { "type": "string", "minLength": 1 },
    "evidence_summary": {
      "type": "object",
      "required": ["candidate_count", "usable_candidate_count", "cohorts", "evidence_ids"],
      "properties": {
        "candidate_count": { "type": "integer", "minimum": 0 },
        "usable_candidate_count": { "type": "integer", "minimum": 0 },
        "cohorts": { "type": "array", "items": { "type": "string", "enum": ["recent", "popular"] } },
        "evidence_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "observed_patterns": { "type": "array", "items": { "type": "object" } },
    "derived_recommendations": { "type": "array", "items": { "type": "object" } },
    "search_intent": { "type": "object" },
    "house_style": { "type": "object" },
    "originality_constraints": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "content_concepts": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "approval_state": { "const": "draft" }
  }
}
