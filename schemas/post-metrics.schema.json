{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viral-bench.local/schemas/post-metrics.schema.json",
  "title": "Post Metrics Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "post_id",
    "job_id",
    "platform",
    "account_handle",
    "posted_url",
    "posted_at",
    "content_type",
    "hook",
    "format",
    "CTA",
    "metric_snapshots",
    "notes"
  ],
  "properties": {
    "post_id": {
      "type": "string",
      "minLength": 1
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "account_handle": {
      "type": "string",
      "minLength": 1
    },
    "posted_url": {
      "type": "string",
      "format": "uri"
    },
    "posted_at": {
      "type": "string",
      "format": "date-time"
    },
    "content_type": {
      "type": "string",
      "minLength": 1
    },
    "hook": {
      "type": "string",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "minLength": 1
    },
    "CTA": {
      "type": "string",
      "minLength": 1
    },
    "experiment_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "variant_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "creative_lane": {
      "type": ["string", "null"],
      "enum": ["image_slideshow", "generated_video", null]
    },
    "delivery_mode": {
      "type": ["string", "null"],
      "enum": ["native_carousel", "rendered_video", null]
    },
    "audio_mode": {
      "type": ["string", "null"],
      "enum": ["platform_commercial_music", "provider_native_audio", "original_audio", "none", null]
    },
    "duration_sec": {
      "type": ["number", "null"],
      "exclusiveMinimum": 0
    },
    "metric_snapshots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metric_snapshot"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "metric_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captured_at",
        "checkpoint",
        "views",
        "likes",
        "comments",
        "shares",
        "saves",
        "follows",
        "profile_visits",
        "dms",
        "average_watch_time_sec",
        "completion_rate",
        "rewatch_rate",
        "measurement_states",
        "notes"
      ],
      "properties": {
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "checkpoint": {
          "enum": ["1h", "24h", "72h", "7d", "custom"]
        },
        "views": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "likes": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "comments": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "shares": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "saves": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "follows": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "profile_visits": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "dms": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "average_watch_time_sec": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "completion_rate": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "rewatch_rate": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "measurement_states": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "views",
            "likes",
            "comments",
            "shares",
            "saves",
            "follows",
            "profile_visits",
            "dms",
            "average_watch_time_sec",
            "completion_rate",
            "rewatch_rate"
          ],
          "properties": {
            "views": { "$ref": "#/$defs/measurement_state" },
            "likes": { "$ref": "#/$defs/measurement_state" },
            "comments": { "$ref": "#/$defs/measurement_state" },
            "shares": { "$ref": "#/$defs/measurement_state" },
            "saves": { "$ref": "#/$defs/measurement_state" },
            "follows": { "$ref": "#/$defs/measurement_state" },
            "profile_visits": { "$ref": "#/$defs/measurement_state" },
            "dms": { "$ref": "#/$defs/measurement_state" },
            "average_watch_time_sec": { "$ref": "#/$defs/measurement_state" },
            "completion_rate": { "$ref": "#/$defs/measurement_state" },
            "rewatch_rate": { "$ref": "#/$defs/measurement_state" }
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "measurement_state": {
      "type": "string",
      "enum": ["observed", "not_available", "not_applicable", "pending"]
    }
  }
}
