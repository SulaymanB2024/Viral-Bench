{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viral-bench.local/schemas/internship-research-batch.schema.json",
  "title": "US Internship Research Batch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "batch_id",
    "purpose",
    "geography",
    "audience",
    "publishing_in_scope",
    "privacy",
    "budget",
    "collection",
    "selection",
    "approval"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "batch_id": { "type": "string", "minLength": 1 },
    "purpose": { "const": "public_us_internship_content_and_market_research" },
    "geography": { "const": "US" },
    "audience": {
      "type": "array",
      "const": ["college_students", "recent_graduates"]
    },
    "publishing_in_scope": { "const": false },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_data_only", "persist_usernames", "persist_profile_urls", "excluded_data"],
      "properties": {
        "public_data_only": { "const": true },
        "persist_usernames": { "const": false },
        "persist_profile_urls": { "const": false },
        "excluded_data": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "hard_cap_usd", "lanes"],
      "properties": {
        "currency": { "const": "USD" },
        "hard_cap_usd": { "type": "number", "exclusiveMinimum": 0, "maximum": 25 },
        "lanes": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "max_usd", "required_credentials", "required_gates"],
            "properties": {
              "id": {
                "type": "string",
                "enum": ["discovery", "audience_voice", "multimodal_analysis", "supplemental_retrieval", "retry_reserve"]
              },
              "max_usd": { "type": "number", "minimum": 0 },
              "required_credentials": {
                "type": "array",
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              },
              "required_gates": {
                "type": "array",
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platforms",
        "cohorts",
        "max_results_per_profile_per_cohort",
        "max_results_per_query_per_cohort",
        "profiles",
        "query_batches",
        "comments",
        "community_sources"
      ],
      "properties": {
        "platforms": {
          "type": "array",
          "const": ["tiktok", "instagram", "youtube_shorts"]
        },
        "cohorts": { "type": "array", "const": ["recent", "popular"] },
        "max_results_per_profile_per_cohort": { "type": "integer", "minimum": 1, "maximum": 6 },
        "max_results_per_query_per_cohort": { "type": "integer", "minimum": 1, "maximum": 8 },
        "profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["company", "platform", "locator", "identity_status", "source_group"],
            "properties": {
              "company": { "type": "string", "minLength": 1 },
              "platform": { "type": "string", "enum": ["tiktok", "instagram", "youtube_shorts"] },
              "locator": { "type": "string", "minLength": 1 },
              "identity_status": { "type": "string", "enum": ["verified_existing_corpus", "official_site_link", "requires_verification"] },
              "source_group": { "const": "competitor_product" }
            }
          }
        },
        "query_batches": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "queries"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "queries": {
                "type": "array",
                "minItems": 10,
                "maxItems": 10,
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "comments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_posts", "max_high_engagement", "max_recent", "max_replies_per_thread"],
          "properties": {
            "target_posts": { "const": 18 },
            "max_high_engagement": { "const": 5 },
            "max_recent": { "const": 5 },
            "max_replies_per_thread": { "const": 2 }
          }
        },
        "community_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["community", "url", "max_items"],
            "properties": {
              "community": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "format": "uri", "pattern": "^https://" },
              "max_items": { "type": "integer", "minimum": 1, "maximum": 12 }
            }
          }
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_total", "group_quotas", "minimum_per_platform", "maximum_per_account"],
      "properties": {
        "target_total": { "const": 36 },
        "group_quotas": {
          "type": "object",
          "additionalProperties": false,
          "required": ["competitor_product", "student_problem_creator", "opportunity_access_safety", "contrast_outlier"],
          "properties": {
            "competitor_product": { "const": 12 },
            "student_problem_creator": { "const": 12 },
            "opportunity_access_safety": { "const": 6 },
            "contrast_outlier": { "const": 6 }
          }
        },
        "minimum_per_platform": { "const": 8 },
        "maximum_per_account": { "const": 3 }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "basis", "approved_at"],
      "properties": {
        "state": { "const": "approved" },
        "basis": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
