{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viral-bench.local/schemas/seo-research-request.schema.json",
  "title": "Bounded SEO Research Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["research_id", "niche", "platforms", "search_queries", "cohorts", "max_results_per_query", "approval", "cost_policy", "house_style"],
  "properties": {
    "research_id": { "type": "string", "minLength": 1 },
    "niche": { "type": "string", "minLength": 1 },
    "strategy_mode": { "type": "string", "enum": ["valuation", "career_guidance"], "default": "valuation" },
    "platforms": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "enum": ["youtube_shorts", "tiktok"] }
    },
    "search_queries": {
      "type": "array", "minItems": 1, "maxItems": 10, "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "cohorts": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "enum": ["recent", "popular"] }
    },
    "max_results_per_query": { "type": "integer", "minimum": 1, "maximum": 50 },
    "approval": {
      "type": "object", "additionalProperties": false,
      "required": ["state", "approved_by", "approved_at"],
      "properties": {
        "state": { "type": "string", "enum": ["draft", "approved", "rejected"] },
        "approved_by": { "type": ["string", "null"], "minLength": 1 },
        "approved_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "cost_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["max_apify_usd"],
      "properties": { "max_apify_usd": { "type": "number", "exclusiveMinimum": 0 } }
    },
    "house_style": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "voice", "recurring_devices", "differentiators"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "voice": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "recurring_devices": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "differentiators": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
