{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viral-bench.local/schemas/video-creative-analysis.schema.json",
  "title": "Video Creative Analysis",
  "type": "object",
  "additionalProperties": false,
  "required": ["analysis_id", "video_asset_id", "model_name", "model_version", "created_at", "duration_sec", "hook", "creative_beats", "visible_proof", "on_screen_text", "speech", "audio_cues", "pacing", "cta", "claims", "style", "evidence_limitations"],
  "properties": {
    "analysis_id": { "type": "string", "minLength": 1 },
    "video_asset_id": { "type": "string", "minLength": 1 },
    "model_name": { "const": "pegasus1.5" },
    "model_version": { "type": "string", "minLength": 1 },
    "model_revision": { "type": ["string", "null"], "minLength": 1 },
    "provider_generation_id": { "type": ["string", "null"], "minLength": 1 },
    "provider_asset_id": { "type": ["string", "null"], "minLength": 1 },
    "provider_analysis_task_id": { "type": ["string", "null"], "minLength": 1 },
    "finish_reason": { "const": "stop" },
    "usage": {
      "type": "object", "additionalProperties": false,
      "required": ["input_tokens", "output_tokens"],
      "properties": {
        "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "output_tokens": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "duration_sec": { "type": "number", "exclusiveMinimum": 0 },
    "hook": { "$ref": "#/$defs/timedText" },
    "creative_beats": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/timed" },
          {
            "type": "object", "additionalProperties": false,
            "required": ["start_sec", "end_sec", "label", "description", "evidence"],
            "properties": {
              "start_sec": { "type": "number", "minimum": 0 },
              "end_sec": { "type": "number", "minimum": 0 },
              "label": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            }
          }
        ]
      }
    },
    "visible_proof": { "type": "array", "items": { "$ref": "#/$defs/timedDescription" } },
    "on_screen_text": { "type": "array", "items": { "$ref": "#/$defs/timedText" } },
    "speech": { "type": "array", "items": { "$ref": "#/$defs/timedText" } },
    "audio_cues": { "type": "array", "items": { "$ref": "#/$defs/timedDescription" } },
    "pacing": {
      "type": "object", "additionalProperties": false,
      "required": ["cuts_per_minute", "pattern"],
      "properties": {
        "cuts_per_minute": { "type": ["number", "null"], "minimum": 0 },
        "pattern": { "type": "string", "minLength": 1 }
      }
    },
    "cta": {
      "type": "object", "additionalProperties": false,
      "required": ["text", "start_sec", "end_sec"],
      "properties": {
        "text": { "type": "string" },
        "start_sec": { "type": ["number", "null"], "minimum": 0 },
        "end_sec": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["text", "start_sec", "end_sec", "support"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "start_sec": { "type": "number", "minimum": 0 },
          "end_sec": { "type": "number", "minimum": 0 },
          "support": { "type": "string", "enum": ["visible", "spoken", "unsupported"] }
        }
      }
    },
    "style": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "evidence_limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "timed": {
      "type": "object",
      "required": ["start_sec", "end_sec"],
      "properties": {
        "start_sec": { "type": "number", "minimum": 0 },
        "end_sec": { "type": "number", "minimum": 0 }
      }
    },
    "timedText": {
      "type": "object", "additionalProperties": false,
      "required": ["start_sec", "end_sec", "text"],
      "properties": {
        "start_sec": { "type": "number", "minimum": 0 },
        "end_sec": { "type": "number", "minimum": 0 },
        "text": { "type": "string" }
      }
    },
    "timedDescription": {
      "type": "object", "additionalProperties": false,
      "required": ["start_sec", "end_sec", "description"],
      "properties": {
        "start_sec": { "type": "number", "minimum": 0 },
        "end_sec": { "type": "number", "minimum": 0 },
        "description": { "type": "string", "minLength": 1 }
      }
    }
  }
}
