{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viral-bench.local/schemas/semantic-search-query.schema.json",
  "title": "Semantic Search Query",
  "type": "object",
  "additionalProperties": false,
  "required": ["query", "embedding_model", "model_version"],
  "properties": {
    "query": { "type": "string", "minLength": 1 },
    "embedding_model": { "const": "marengo3.0" },
    "model_version": { "type": "string", "minLength": 1 },
    "limit": { "type": "integer", "minimum": 1, "maximum": 200 },
    "filters": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "platforms": { "type": "array", "uniqueItems": true, "items": { "type": "string", "enum": ["tiktok", "instagram", "youtube_shorts"] } },
        "accounts": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "hashtags": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "date_from": { "type": "string", "format": "date-time" },
        "date_to": { "type": "string", "format": "date-time" }
      }
    }
  }
}
